// cl.haus LLM Proxy — Model Provider for OpenClaw
//
// Add this to your openclaw.json under "models.providers".
// Replace <YOUR_HOME_ID> and <YOUR_API_KEY> with your cl.haus credentials.
//
// This routes LLM calls through cl.haus's metered proxy.
// Token usage is tracked per-home for billing.
// The model aliases (claus-standard, claus-lite, claus-micro) resolve
// to real backend models on the server side — you never need to
// know or configure which provider model is behind them.
//
// IMPORTANT:
// - "api" must be "openai-completions" (NOT "anthropic-messages" or "openai")
// - "baseUrl" must end with /llm/v1 (OpenClaw appends /chat/completions)
// - "models.mode" should be "merge" to keep any existing providers
{
  "claus": {
    "baseUrl": "https://cl.haus/api/homes/<YOUR_HOME_ID>/llm/v1",
    "apiKey": "<YOUR_API_KEY>",
    "api": "openai-completions",
    "models": [
      {
        "id": "claus-standard",
        "name": "Claus Standard",
        "reasoning": true,
        "input": ["text", "image"],
        "contextWindow": 400000,
        "maxTokens": 16384
      },
      {
        "id": "claus-lite",
        "name": "Claus Lite",
        "reasoning": false,
        "input": ["text", "image"],
        "contextWindow": 131072,
        "maxTokens": 8192
      },
      {
        "id": "claus-micro",
        "name": "Claus Micro",
        "reasoning": true,
        "input": ["text", "image"],
        "contextWindow": 400000,
        "maxTokens": 16384
      }
    ]
  }
}
